{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "Grafana Cloud Prometheus / any Prometheus datasource",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "title": "WC 2026 Forecast — Model Monitor",
  "uid": "wc2026-monitor",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "panels": [
    {
      "id": 1, "type": "stat", "gridPos": { "x": 0, "y": 0, "w": 4, "h": 4 },
      "title": "Prob Sum %",
      "description": "Sum of all team win probabilities — should be ~100%",
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "none" },
      "fieldConfig": {
        "defaults": {
          "unit": "percent", "decimals": 1,
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "red", "value": null },
            { "color": "yellow", "value": 90 },
            { "color": "green", "value": 95 },
            { "color": "yellow", "value": 105 },
            { "color": "red", "value": 110 }
          ]}
        }
      },
      "targets": [{ "datasource": { "type": "prometheus" }, "expr": "wc2026_prob_sum_pct", "legendFormat": "Prob Sum" }]
    },
    {
      "id": 2, "type": "stat", "gridPos": { "x": 4, "y": 0, "w": 4, "h": 4 },
      "title": "Shannon Entropy (bits)",
      "description": "Drops as a clear favourite emerges. Max ~5.6 bits (48 equal teams).",
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "none" },
      "fieldConfig": {
        "defaults": {
          "unit": "short", "decimals": 3,
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 4 },
            { "color": "red", "value": 5 }
          ]}
        }
      },
      "targets": [{ "datasource": { "type": "prometheus" }, "expr": "wc2026_entropy_bits", "legendFormat": "Entropy" }]
    },
    {
      "id": 3, "type": "stat", "gridPos": { "x": 8, "y": 0, "w": 4, "h": 4 },
      "title": "Matches Ingested",
      "description": "Completed WC matches from ESPN. Max 72 (group stage).",
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "none" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "yellow", "value": null },
            { "color": "green", "value": 1 }
          ]}
        }
      },
      "targets": [{ "datasource": { "type": "prometheus" }, "expr": "wc2026_match_count", "legendFormat": "Matches" }]
    },
    {
      "id": 4, "type": "stat", "gridPos": { "x": 12, "y": 0, "w": 4, "h": 4 },
      "title": "Guardrail Warnings",
      "description": "0 = all model invariants passing",
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "none" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 1 },
            { "color": "red", "value": 3 }
          ]}
        }
      },
      "targets": [{ "datasource": { "type": "prometheus" }, "expr": "wc2026_guardrail_warnings", "legendFormat": "Warnings" }]
    },
    {
      "id": 5, "type": "stat", "gridPos": { "x": 16, "y": 0, "w": 4, "h": 4 },
      "title": "Sim Duration (s)",
      "description": "Wall-clock time for the last full pipeline run",
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "none" },
      "fieldConfig": {
        "defaults": {
          "unit": "s", "decimals": 1,
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 120 },
            { "color": "red", "value": 300 }
          ]}
        }
      },
      "targets": [{ "datasource": { "type": "prometheus" }, "expr": "wc2026_sim_duration_seconds", "legendFormat": "Duration" }]
    },
    {
      "id": 6, "type": "stat", "gridPos": { "x": 20, "y": 0, "w": 4, "h": 4 },
      "title": "Cache Age (s)",
      "description": "Seconds since the last simulation completed. TTL = 3600s.",
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "none" },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 3600 },
            { "color": "red", "value": 7200 }
          ]}
        }
      },
      "targets": [{ "datasource": { "type": "prometheus" }, "expr": "wc2026_cache_age_seconds", "legendFormat": "Cache Age" }]
    },
    {
      "id": 7, "type": "timeseries", "gridPos": { "x": 0, "y": 4, "w": 24, "h": 8 },
      "title": "Championship Win Probability — Top Teams Over Time (%)",
      "description": "Watch probabilities shift as matches are played",
      "fieldConfig": {
        "defaults": { "unit": "percent", "custom": { "lineWidth": 2, "fillOpacity": 8 } }
      },
      "targets": [
        { "datasource": { "type": "prometheus" }, "expr": "wc2026_team_win_prob_pct{team=\"Argentina\"}", "legendFormat": "🇦🇷 Argentina" },
        { "datasource": { "type": "prometheus" }, "expr": "wc2026_team_win_prob_pct{team=\"France\"}", "legendFormat": "🇫🇷 France" },
        { "datasource": { "type": "prometheus" }, "expr": "wc2026_team_win_prob_pct{team=\"Spain\"}", "legendFormat": "🇪🇸 Spain" },
        { "datasource": { "type": "prometheus" }, "expr": "wc2026_team_win_prob_pct{team=\"England\"}", "legendFormat": "🏴󠁧󠁢󠁥󠁮󠁧󠁿 England" },
        { "datasource": { "type": "prometheus" }, "expr": "wc2026_team_win_prob_pct{team=\"Germany\"}", "legendFormat": "🇩🇪 Germany" },
        { "datasource": { "type": "prometheus" }, "expr": "wc2026_team_win_prob_pct{team=\"Brazil\"}", "legendFormat": "🇧🇷 Brazil" },
        { "datasource": { "type": "prometheus" }, "expr": "wc2026_team_win_prob_pct{team=\"Portugal\"}", "legendFormat": "🇵🇹 Portugal" }
      ]
    },
    {
      "id": 8, "type": "timeseries", "gridPos": { "x": 0, "y": 12, "w": 12, "h": 7 },
      "title": "Model Calibration — Probability Sum & Entropy",
      "fieldConfig": { "defaults": { "custom": { "lineWidth": 2 } } },
      "targets": [
        { "datasource": { "type": "prometheus" }, "expr": "wc2026_prob_sum_pct", "legendFormat": "Prob Sum %" },
        { "datasource": { "type": "prometheus" }, "expr": "wc2026_entropy_bits * 10", "legendFormat": "Entropy × 10 (bits)" }
      ]
    },
    {
      "id": 9, "type": "timeseries", "gridPos": { "x": 12, "y": 12, "w": 12, "h": 7 },
      "title": "Chat API — Requests by Outcome",
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "lineWidth": 2 } } },
      "targets": [
        { "datasource": { "type": "prometheus" }, "expr": "rate(wc2026_chat_requests_total{outcome=\"success\"}[5m])", "legendFormat": "success" },
        { "datasource": { "type": "prometheus" }, "expr": "rate(wc2026_chat_requests_total{outcome=\"rate_limited\"}[5m])", "legendFormat": "rate_limited" },
        { "datasource": { "type": "prometheus" }, "expr": "rate(wc2026_chat_requests_total{outcome=\"jailbreak\"}[5m])", "legendFormat": "jailbreak" },
        { "datasource": { "type": "prometheus" }, "expr": "rate(wc2026_chat_requests_total{outcome=\"error\"}[5m])", "legendFormat": "error" }
      ]
    },
    {
      "id": 10, "type": "timeseries", "gridPos": { "x": 0, "y": 19, "w": 12, "h": 7 },
      "title": "Chat Latency (p50 / p95 / p99)",
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "lineWidth": 2 } } },
      "targets": [
        { "datasource": { "type": "prometheus" }, "expr": "histogram_quantile(0.50, rate(wc2026_chat_latency_seconds_bucket[5m]))", "legendFormat": "p50" },
        { "datasource": { "type": "prometheus" }, "expr": "histogram_quantile(0.95, rate(wc2026_chat_latency_seconds_bucket[5m]))", "legendFormat": "p95" },
        { "datasource": { "type": "prometheus" }, "expr": "histogram_quantile(0.99, rate(wc2026_chat_latency_seconds_bucket[5m]))", "legendFormat": "p99" }
      ]
    },
    {
      "id": 11, "type": "timeseries", "gridPos": { "x": 12, "y": 19, "w": 12, "h": 7 },
      "title": "Tournament Progress — Matches Ingested & Fixtures Remaining",
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "lineWidth": 2 } } },
      "targets": [
        { "datasource": { "type": "prometheus" }, "expr": "wc2026_match_count", "legendFormat": "Matches completed" },
        { "datasource": { "type": "prometheus" }, "expr": "wc2026_fixture_count", "legendFormat": "Fixtures remaining" }
      ]
    }
  ]
}
